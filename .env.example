# Non-sensitive or less sensitive config
# Copy this file to .env and adjust values.

# Optional comma-separated list of Telegram user IDs
ALLOWED_USER_IDS=123456789

# Optional comma-separated phone numbers (digits only).
# Use: 393311234567,393491112233
# Avoid: +39 331 123 4567
ALLOWED_PHONE_NUMBERS=391234567890
